# ===============================
# PLANTILLA OFICIAL DE UNITY
# ===============================

# Los directorios que Unity genera localmente
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Archivos de bloqueo y caché
*.log
*.pidb
*.pdb
*.mdb
*.opendb
*.VC.db

# Archivos de solución de Visual Studio
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.booproj
*.svd

# Archivos de informes de fallos
sysinfo.txt
mono_crash.*

# Archivos generados por Unity
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Archivos de paquetes exportados
*.unitypackage
*.unitypackage.meta

# Archivos de construcción de Android / iOS
*.apk
*.aab
*.app

# Archivos de Addressables
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Archivos de Visual Scripting
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Archivos de caché en Assets
/[Aa]ssets/[Ss]ceneDependencyCache*

# Archivos de Editores / SO (opcionales)
.DS_Store
Thumbs.db
.vs/
.gradle/
/.idea/

# Archivos específicos de JetBrains Rider
*.DotSettings.user
/[Aa]ssets/Plugins/Editor/JetBrains*

# Archivos de Blender (si usas modelos .blend)
*.blend1
*.blend1.meta

# Capturas de memoria (pueden ser muy grandes)
/[Mm]emoryCaptures/

# Grabaciones
/[Rr]ecordings/

# Archivos de TestRunner
InitTestScene*.unity*

# Archivos de Crashlytics
crashlytics-build.properties

# Archivos que puedas querer ignorar (descomentar si aplica)
# /[Aa]ssets/AssetStoreTools*
# /[Aa]ssets/Plugins/Editor/JetBrains*

# ===============================
# PERSONALIZACIONES ADICIONALES
# ===============================

# Si usas Git LFS para archivos grandes, agrega esto:
# *.fbx filter=lfs diff=lfs merge=lfs -text
# *.png filter=lfs diff=lfs merge=lfs -text
# *.jpg filter=lfs diff=lfs merge=lfs -text
# *.wav filter=lfs diff=lfs merge=lfs -text